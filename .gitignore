# Ignore Node.js Modules
node_modules/
*/node_modules/

# Ignore Environment Variables (Keep secrets safe!)
.env
.env.*
!.env.example
*/.env
*/.env.*
!*/.env.example

# Next.js Build Output
.next/
out/
build/
*/.next/
*/out/
*/build/

# Backend Uploads (Don't push user-uploaded images)
quiz-backend/uploads/*
!quiz-backend/uploads/.gitkeep

# Mac/Windows OS Files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Vercel
.vercel
